# Backend environment variables
# Copy this file to .env and fill in values before running

PORT=3001
NODE_ENV=development

# Database
DB_PATH=./data/taskflow.db

# JWT — change this to a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# SMTP (for password reset emails — optional in dev, console logs token instead)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=TaskFlow <noreply@example.com>
