# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="debug"

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/myapp"
# Connection pool size — set to 1 when using a cloud pooler (Supabase :6543, Neon PgBouncer)
# DB_POOL_MAX="10"

# Auth (NextAuth v5 / Auth.js)
# Note: AUTH_URL is auto-detected in most envs, only needed behind a proxy
AUTH_SECRET=""              # openssl rand -base64 32
# AUTH_URL="http://localhost:3000"

# OAuth Providers (auto-detected by NextAuth from variable names)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Docker DB
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="myapp"
